# Configuracion SAP
# Copia este archivo como .env y completa la lista de sistemas SAP.
# La variable SAP_SYSTEMS_JSON acepta JSON multilínea para que pueda editarse manualmente.

SAP_SYSTEMS_JSON='[
  {
    "id": "DEV",
    "name": "Servidor de Desarrollo",
    "type": "Desarrollo",
    "server": "https://host-dev:port",
    "user": "tu_usuario_dev",
    "password": "tu_password_dev",
    "client": "500",
    "language": "EN",
    "verify_ssl": false
  },
  {
    "id": "QAS",
    "name": "Servidor de Calidad",
    "type": "Calidad",
    "server": "https://host-qas:port",
    "user": "tu_usuario_qas",
    "password": "tu_password_qas",
    "client": "500",
    "language": "EN",
    "verify_ssl": false
  }
]'

# Compatibilidad legacy opcional para un unico sistema:
# SAP_SYSTEM_ID=DEF
# SAP_SYSTEM_NAME=Default SAP System
# SAP_SYSTEM_TYPE=Default
# SAP_SERVER=https://host:port
# SAP_USER=tu_usuario
# SAP_PASSWORD=tu_password
# SAP_CLIENT=500
# SAP_LANGUAGE=EN
# SAP_VERIFY_SSL=false
